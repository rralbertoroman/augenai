# ── Supabase: database (Postgres connection string, not an API key) ──
# Transaction pooler (6543) for serverless; session pooler/direct (5432) for a long-lived server.
SUPABASE_DB_URL=postgresql://postgres.xxx:password@aws-0-us-east-0.pooler.supabase.com:6543/postgres

# ── Supabase: API keys (new opaque keys; legacy anon/service_role retired end-2026) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key   # public, browser-safe
SUPABASE_SECRET_KEY=sb_secret_your_secret_key                          # server-only, bypasses RLS
# NOTE: user JWTs are verified via the JWKS endpoint derived from NEXT_PUBLIC_SUPABASE_URL —
# no SUPABASE_JWT_JWK needed anymore (rotation handled automatically).

# ── AI prediction service ──
# AI_PREDICTION_SERVICE_SECRET_KEY MUST match apps/ai_service/.env
AI_PREDICTION_SERVICE_URL=http://localhost:8000/api/v1
AI_PREDICTION_SERVICE_SECRET_KEY=your_shared_secret_key

# ── Email (Nodemailer → Gmail SMTP; free within ~500/day) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                       # true for port 465, false for 587/STARTTLS
SMTP_USER=youraddress@gmail.com         # your real Gmail address (the authenticating account)
SMTP_PASS=your_16_char_app_password     # Gmail App Password (NOT your login password; requires 2FA)
EMAIL_FROM=AugenAI <youraddress+augenai@gmail.com>   # a verified "send mail as" alias
CONTACT_EMAIL=contact@your-domain.com

# ── App config (optional) ──
ENVIRONMENT=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000     # used to build share links in emails
# NEXT_PUBLIC_API_URL=http://ai-service:8000    # Docker /api/* rewrite target
