# Use the official Node.js image for development
FROM node:20-alpine

# Install pnpm globally
RUN npm install -g pnpm

# Set the working directory inside the container
WORKDIR /app

# Copy root files needed for pnpm workspace
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy only the web app directory (not other apps that may have Python deps)
COPY apps/web ./apps/web

# Copy shared packages if they exist
COPY packages/ ./packages/

# Install only the web app dependencies, skipping prepare scripts that might invoke Python
RUN pnpm install --frozen-lockfile --filter web... --ignore-scripts

# Set the working directory to the web app
WORKDIR /app/apps/web

# Expose the port Next.js runs on
EXPOSE 3000

# Set the default command to run the development server
CMD ["pnpm", "dev"]